entrypoint = "README.md"
modules = ["nodejs-22", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["imagemagick"]

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["resend:1.0.0", "javascript_openai_ai_integrations:2.0.0", "elevenlabs:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run expo:dev"
waitForPort = 8081
ensurePreviewReachable = "/status"

[userenv]

[userenv.shared]
TZ = "America/Chicago"
TRUSTLAYER_BASE_URL = "https://dwsc.io"
ORBIT_HUB_URL = "https://orbitstaffing.io"
VERDARA_BASE_URL = "https://verdara.replit.app"
TRUSTVAULT_BASE_URL = "https://trustvault.replit.app"
ORBIT_STAFFING_API_KEY = "dw_app_187d8d3a74e0f3bd22ab4a81a4a8e11c23e39f50a16ff514"
ORBIT_STAFFING_API_SECRET = "dw_secret_af259a1340d68bf1395efccc57ea53dc301dec9c824c386493328cd7e201a038"
